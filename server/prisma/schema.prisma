generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  AGENT
  CUSTOMER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MessageType {
  TEXT
  IMAGE
  FILE
}

enum ChatStatus {
  ACTIVE
  WAITING
  TRANSFERRED
  CLOSED
}

enum BackupStatus {
  SUCCESS
  FAILED
  IN_PROGRESS
}

enum GDPRRequestType {
  EXPORT
  DELETE
}

enum GDPRRequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum AlertSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  role          Role           @default(CUSTOMER)
  language      String         @default("en")
  isActive      Boolean        @default(true)
  twoFactorOn   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tickets       Ticket[]       @relation("CustomerTickets")
  assigned      Ticket[]       @relation("AgentTickets")
  messages      Message[]
  customerChats ChatSession[]  @relation("CustomerChats")
  agentChats    ChatSession[]  @relation("AgentChats")
  logs          ActivityLog[]
  notifications Notification[]
  twoFactorTokens TwoFactorToken[]
  recoveryCodes RecoveryCode[]
  backupLogs    BackupLog[]
  gdprRequests  GDPRRequest[] @relation("GDPRRequestUser")
  gdprReviews   GDPRRequest[] @relation("GDPRReviewUser")
  internalMessages InternalMessage[]
  openedInternalChats InternalChat[] @relation("InternalChatOpenedBy")
  internalParticipations InternalParticipant[]
}

model Ticket {
  id          String         @id @default(cuid())
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  category    String
  customerId  String
  agentId     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  firstResponseAt DateTime?
  resolvedAt   DateTime?
  firstResponseMinutes Int?
  resolutionMinutes Int?
  slaBreached Boolean        @default(false)
  customer    User           @relation("CustomerTickets", fields: [customerId], references: [id])
  agent       User?          @relation("AgentTickets", fields: [agentId], references: [id])
  messages    Message[]
  attachments Attachment[]
}

model Message {
  id            String       @id @default(cuid())
  content       String
  originalContent String?
  translatedContent String?
  sourceLanguage String?
  targetLanguage String?
  encryptionVersion String?
  senderId      String
  ticketId      String?
  chatSessionId String?
  isAI          Boolean      @default(false)
  fileUrl       String?
  messageType   MessageType  @default(TEXT)
  createdAt     DateTime     @default(now())
  sender        User         @relation(fields: [senderId], references: [id])
  ticket        Ticket?      @relation(fields: [ticketId], references: [id])
  chatSession   ChatSession? @relation(fields: [chatSessionId], references: [id])
}

model ChatSession {
  id         String     @id @default(cuid())
  customerId String
  agentId    String?
  status     ChatStatus @default(WAITING)
  rating     Int?
  feedback   String?
  language   String     @default("en")
  channel    String     @default("Website chatbot")
  encrypted  Boolean    @default(true)
  lastMessage String?
  visitorIp  String?
  visitorPage String?
  visitorDevice String?
  visitorVisits Int     @default(1)
  visitorId  String?
  visitorDomain String?
  visitorReferrer String?
  widgetId String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  customer   User       @relation("CustomerChats", fields: [customerId], references: [id])
  agent      User?      @relation("AgentChats", fields: [agentId], references: [id])
  messages   Message[]
}

model InternalChat {
  id          String            @id @default(cuid())
  subject     String
  ticketId    String?
  openedById  String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  openedBy    User              @relation("InternalChatOpenedBy", fields: [openedById], references: [id])
  participants InternalParticipant[]
  messages    InternalMessage[]
}

model InternalParticipant {
  id        String       @id @default(cuid())
  chatId    String
  userId    String
  role      Role
  createdAt DateTime     @default(now())
  chat      InternalChat @relation(fields: [chatId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@unique([chatId, userId])
}

model InternalMessage {
  id        String       @id @default(cuid())
  chatId    String
  senderId  String
  content   String
  fileUrl   String?
  fileName  String?
  fileType  String?
  createdAt DateTime     @default(now())
  chat      InternalChat @relation(fields: [chatId], references: [id])
  sender    User         @relation(fields: [senderId], references: [id])
}

model Attachment {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileType  String
  ticketId  String?
  createdAt DateTime @default(now())
  ticket    Ticket?  @relation(fields: [ticketId], references: [id])
}

model AIConfig {
  id                        String   @id @default(cuid())
  botName                   String   @default("Support AI")
  welcomeMessage            String
  fallbackMessage           String
  isActive                  Boolean  @default(true)
  autoTranslate             Boolean  @default(true)
  handoffAfterFailedReplies Int      @default(2)
  supportedLanguages        String[] @default(["en", "it", "es", "fr"])
  regionalNotes             String   @default("")
  regionalProfiles          Json     @default("{}")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model IntegrationSetting {
  id        String   @id @default(cuid())
  type      String   @unique
  config    Json
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TwoFactorToken {
  id                 String   @id @default(cuid())
  userId             String
  tokenHash          String
  tempLoginTokenHash String   @unique
  expiresAt          DateTime
  attempts           Int      @default(0)
  used               Boolean  @default(false)
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id])
}

model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  used      Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model BackupLog {
  id           String       @id @default(cuid())
  fileName     String
  filePath     String?
  provider     String       @default("local")
  status       BackupStatus @default(IN_PROGRESS)
  sizeBytes    Int          @default(0)
  createdById  String?
  errorMessage String?
  createdAt    DateTime     @default(now())
  createdBy    User?        @relation(fields: [createdById], references: [id])
}

model GDPRRequest {
  id           String            @id @default(cuid())
  userId       String
  type         GDPRRequestType
  status       GDPRRequestStatus @default(PENDING)
  requestedById String?
  reviewedById String?
  reason       String?
  adminNote    String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  completedAt  DateTime?
  user         User              @relation("GDPRRequestUser", fields: [userId], references: [id])
  reviewedBy   User?             @relation("GDPRReviewUser", fields: [reviewedById], references: [id])
}

model AIUsageLog {
  id          String   @id @default(cuid())
  provider    String
  model       String
  endpoint    String
  success     Boolean  @default(true)
  tokensIn    Int      @default(0)
  tokensOut   Int      @default(0)
  errorMessage String?
  userId      String?
  createdAt   DateTime @default(now())
}

model SystemAlert {
  id         String        @id @default(cuid())
  type       String
  severity   AlertSeverity @default(INFO)
  title      String
  message    String
  isResolved Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
}
